# Database
DATABASE_URL=postgresql://mir:mir@localhost:5432/mir

# LLM Provider: anthropic, openai, or gemini
LLM_PROVIDER=anthropic
LLM_API_KEY=your-api-key-here
# LLM_MODEL=  # Optional: auto-selected per provider

# Authentication
AUTH_EMAIL=admin@example.com
AUTH_PASSWORD=changeme
AUTH_SECRET=change-this-to-a-random-string

# Scraping (optional — falls back to requests+beautifulsoup)
# FIRECRAWL_API_KEY=

# Enrichment (optional — gracefully skipped if not set)
# APOLLO_API_KEY=
# SALESQL_API_KEY=
